{
  "enabled": true,
  "rules": [
    {
      "name": "CCTV WebView 优先",
      "description": "央视 CCTV 频道优先选择来源、标题或 URL 中带 WebView 的源。命中后仍经过可播放、清晰度、CatVod/解析源清理等流程。",
      "channelNamePatterns": [
        "^CCTV-"
      ],
      "groupPatterns": [
        "^央视$"
      ],
      "preferPatterns": [
        "WebView",
        "webview",
        "web-view",
        "Web View"
      ],
      "boost": 2500000
    },
    {
      "name": "广东卫视避开 219.137 新闻源",
      "description": "219.137.203.143:9901 这组候选更符合广东新闻频道，不再让它顶到广东卫视主源。",
      "channelNamePatterns": [
        "^广东卫视$"
      ],
      "groupPatterns": [],
      "preferPatterns": [
        "219\\.137\\.203\\.143:9901",
        "219.137.203.143:9901"
      ],
      "boost": -5000000
    },
    {
      "name": "广东新闻 219.137 优先",
      "description": "用户反馈 219.137.203.143:9901 源对应广东新闻频道，速度和清晰度较好。只在广东新闻频道中优先使用。",
      "channelNamePatterns": [
        "^广东新闻$"
      ],
      "groupPatterns": [],
      "preferPatterns": [
        "219\\.137\\.203\\.143:9901",
        "219.137.203.143:9901"
      ],
      "boost": 2200000
    }
  ]
}
