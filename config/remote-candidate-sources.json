{
  "notes": "远程自动更新候选源配置。这里的源会先经过 build-remote-candidates.mjs 清洗，排除 CatVod、TVBox、点播接口、JSON/JAR/HTML/PHP 代理等不能直接播放的地址，再输出到 m3u/remote-candidates.m3u。build-custom.mjs 只从清洗后的本地文件参与匹配和测速。",
  "sources": [
    {
      "name": "hujingguang/ChinaIPTV cnTV_AutoUpdate",
      "url": "https://raw.githubusercontent.com/hujingguang/ChinaIPTV/main/cnTV_AutoUpdate.m3u8",
      "timeoutMs": 12000,
      "type": "third-party-auto-update",
      "priority": "candidate",
      "notes": "第三方自动更新聚合源，只作为候选池。"
    }
  ],
  "filter": {
    "allowHttpOnly": true,
    "acceptedUrlPatterns": [
      "\\.m3u8(\\?|$)",
      "\\.m3u(\\?|$)",
      "/PLTV/",
      "/hls/",
      "/live/",
      "m3u8"
    ],
    "blockedUrlPatterns": [
      "catvod",
      "tvbox",
      "drpy",
      "spider",
      "csp_",
      "csp-",
      "\\.jar(\\?|$)",
      "\\.json(\\?|$)",
      "\\.js(\\?|$)",
      "\\.apk(\\?|$)",
      "\\.html?(\\?|$)",
      "api\\.php.*provide.*vod",
      "/provide/vod",
      "/vod/",
      "player",
      "parse",
      "jx=",
      "url=catvod",
      "douban",
      "alist"
    ],
    "blockedTitlePatterns": [
      "CatVod",
      "TVBox",
      "点播",
      "影视接口",
      "解析",
      "嗅探"
    ]
  }
}
